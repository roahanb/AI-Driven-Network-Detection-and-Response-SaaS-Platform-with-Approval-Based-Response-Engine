# AI-NDR Platform - Production Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://ndr_user:YOUR_STRONG_PASSWORD@db:5432/ai_ndr_prod

# Security
SECRET_KEY=YOUR_GENERATED_SECRET_KEY_HERE
# Generate with: openssl rand -hex 32

# Domain & CORS
DOMAIN=roahacks.com
ALLOWED_ORIGINS=https://roahacks.com,https://app.roahacks.com,https://api.roahacks.com
ENVIRONMENT=production

# Logging
LOG_LEVEL=INFO

# Performance
MAX_WORKERS=8
WORKER_TIMEOUT=120

# Redis (optional)
REDIS_URL=redis://redis:6379/0

# SMTP (for notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Slack Webhooks (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
