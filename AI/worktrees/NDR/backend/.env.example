# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI-NDR SaaS Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ndr_user:ndr_password@db:5432/ndr_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_256_BIT_RANDOM_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://your-domain.com"]

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@your-domain.com

# ── Slack ─────────────────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── ML Model ──────────────────────────────────────────────────────────────────
ML_MODEL_PATH=saved_models/isolation_forest.pkl
ML_CONTAMINATION=0.1
